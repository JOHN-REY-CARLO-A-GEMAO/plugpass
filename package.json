{
  "name": "plugpass",
  "version": "0.1.0",
  "description": "AI plugin trust registry — scan, score, and verify browser extensions before installation",
  "author": "Plugpass",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/plugpass"
  },
  "keywords": [
    "chrome-extension",
    "security",
    "privacy",
    "ai-plugins",
    "risk-scoring",
    "trust-registry",
    "manifest-parser",
    "browser-security"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "npx prisma migrate dev --name init && npx tsx scripts/seed.ts",
    "db:import-local": "npx tsx scripts/import-local.ts",
    "db:push": "npx prisma db push",
    "db:push:prod": "npx prisma db push --schema prisma/schema.postgres.prisma",
    "db:reset": "npx prisma migrate reset --force && npx tsx scripts/seed.ts",
    "db:seed:prod": "npx tsx scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "gif-encoder-2": "^1.0.5",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "puppeteer": "^25.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
